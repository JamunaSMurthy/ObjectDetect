# Environment Configuration Template
# Copy this file to .env and update values for your system

# GPU Configuration
CUDA_VISIBLE_DEVICES=0  # GPU device ID (0, 1, 2...) or -1 for CPU only

# Faster R-CNN Configuration
FASTER_RCNN_MODEL_PATH=./models/efficientdet_d0_coco17_tpu-32/saved_model
FASTER_RCNN_LABEL_MAP=./models/mscoco_label_map.pbtxt
FASTER_RCNN_THRESHOLD=0.4
FASTER_RCNN_INPUT_SIZE=640

# YOLO Configuration
YOLO_WEIGHTS_PATH=./models/YOLO_bdd100k.pt
YOLO_GRID_SIZE=14
YOLO_CONFIDENCE_THRESHOLD=0.45
YOLO_NMS_THRESHOLD=0.5
YOLO_INPUT_SIZE=448
YOLO_NUM_CLASSES=13
YOLO_NUM_BOXES=2

# Training Configuration
BATCH_SIZE=10
LEARNING_RATE=1e-5
NUM_EPOCHS=100
LAMBDA_COORD=5.0
LAMBDA_NOOBJ=0.5

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE_SIZE=10485760  # 10MB in bytes
LOG_BACKUP_COUNT=5

# Input/Output Directories
DATA_DIR=./data
OUTPUT_DIR=./output
MODEL_OUTPUT_DIR=./checkpoints

# Other Settings
USE_CPU_ONLY=false
RANDOM_SEED=42
NUM_WORKERS=4
PREFETCH_FACTOR=2
